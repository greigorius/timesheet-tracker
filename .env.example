# Timesheet Tracker — Axiom DL
# Local reference only. Copy to .env and fill in your values.
# .env is git-ignored and NOT read by the app — paste values into the Settings drawer (⚙) instead.

# Make.com webhooks
MAKE_SCAN_WEBHOOK=https://hook.eu1.make.com/XXXX     # Scenario B — Scan Inbox
MAKE_WRITE_WEBHOOK=https://hook.eu1.make.com/XXXX    # Scenario A — Full Import

# Notion
NOTION_TOKEN=ntn_XXXX                                # Internal integration token
NOTION_TIMESHEETS_DB=197210e4-582e-8087-81be-000b8525577a
NOTION_PROJECTS_DB=5c689434-c2b0-4766-9831-d2b31ef0f8de

# Notion proxy (deployed on Axiom Hub — greigorius/dm-tracker)
PROXY_URL=https://axiom-hub.netlify.app/api/notion/query

# Claude API (used inside Make scenarios — store in Make's connection, not here)
# ANTHROPIC_API_KEY=sk-ant-XXXX
