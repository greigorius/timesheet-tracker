# Timesheet Tracker — Axiom DL
# Local reference / cheat-sheet. .env is git-ignored.
#
# ┌─────────────────────────────────────────────────────────────┐
# │  COCKPIT SETTINGS (paste into ⚙ Settings drawer in the app) │
# └─────────────────────────────────────────────────────────────┘

MAKE_SCAN_WEBHOOK=https://hook.eu1.make.com/XXXX     # Scenario B — Scan Inbox
MAKE_WRITE_WEBHOOK=https://hook.eu1.make.com/XXXX    # Scenario A — Full Import

# Proxy URL — default works on Netlify without changes:
PROXY_URL=/.netlify/functions/notion-proxy

# ┌─────────────────────────────────────────────────────────────┐
# │  NETLIFY ENV VARS (set in Netlify → Site → Environment)     │
# │  These stay server-side and are never in the browser.       │
# └─────────────────────────────────────────────────────────────┘

NOTION_TOKEN=ntn_XXXX                                # Read-only internal integration token
NOTION_TIMESHEETS_DB=197210e4-582e-8074-af63-f01e789e2d1c
NOTION_PROJECTS_DB=5c689434-c2b0-4766-9831-d2b31ef0f8de

# ┌─────────────────────────────────────────────────────────────┐
# │  MAKE.COM (stored in Make connections, not here)            │
# └─────────────────────────────────────────────────────────────┘

# ANTHROPIC_API_KEY=sk-ant-XXXX
